# ─── Core ─────────────────────────────────────────────────────────────
ANTHROPIC_KEY=

# ─── Google OAuth (Calendar + Gmail read-only) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_TOKEN_PATH=./data/google-token.json

# ─── Web Search (pick one) ────────────────────────────────────────────
TAVILY_KEY=
# BRAVE_KEY=

# ─── Optional flags ───────────────────────────────────────────────────
# Local Whisper model: tiny.en | base.en | small.en | medium.en
# MJ_WHISPER_MODEL=base.en
# macOS `say` voice (run `say -v ?` to list). Daniel is a good JARVIS pick.
# MJ_TTS_VOICE=Daniel
# MJ_TTS_RATE=185
# Disable screen capture entirely (overrides any agent attempt)
# MJ_DISABLE_SCREEN=1
# Reduce particle count on low-end GPUs
# MJ_LOW_GFX=1

# ─── Optional cloud overrides (only set if you want cloud STT/TTS) ────
# OPENAI_KEY=
# ELEVEN_KEY=
# ELEVEN_VOICE_ID=
# Optional hands-free wake word (https://console.picovoice.ai/)
# PORCUPINE_ACCESS_KEY=
