# ─── Core (required) ──────────────────────────────────────────────────
ANTHROPIC_KEY=
# Override Gwen's brain model (default: claude-haiku-4-5-20251001)
# GWEN_BRAIN_MODEL=

# ─── Speech-to-text (all optional — local whisper.cpp is the fallback) ─
# Preferred: Groq (whisper-large-v3-turbo, fastest cloud STT)
# GROQ_KEY=
# Alternative cloud STT: OpenAI (whisper-1)
# OPENAI_KEY=
# With neither key set, Gwen transcribes locally via nodejs-whisper.
# Local model: tiny.en | base.en | small.en | medium.en (default: base.en)
# GWEN_WHISPER_MODEL=base.en

# ─── Text-to-speech (all optional — macOS `say` is the fallback) ───────
# Preferred: Fish Audio
# FISH_KEY=
# FISH_VOICE_ID=
# Alternative: ElevenLabs
# ELEVEN_KEY=
# ELEVEN_VOICE_ID=
# Force a provider: fish | eleven | say (default: auto by key presence)
# GWEN_TTS_PROVIDER=
# macOS `say` fallback voice (run `say -v ?` to list) + rate
# GWEN_TTS_VOICE=Daniel
# GWEN_TTS_RATE=185

# ─── Google OAuth (Calendar + Gmail read-only) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_TOKEN_PATH=./data/google-token.json

# ─── Web Search (pick one) ────────────────────────────────────────────
TAVILY_KEY=
# BRAVE_KEY=

# ─── Optional flags ───────────────────────────────────────────────────
# Disable screen capture entirely (overrides any agent attempt)
# GWEN_DISABLE_SCREEN=1
# Optional hands-free wake word (https://console.picovoice.ai/)
# PORCUPINE_ACCESS_KEY=
