# ─── Core routing ─────────────────────────────────────────────────────
# Brain provider: auto | anthropic | ollama. Auto chooses the cheapest capable
# route for the turn and logs decisions to data/model-router.jsonl.
GWEN_BRAIN_PROVIDER=auto
GWEN_DEFAULT_PROVIDER=anthropic
GWEN_DISCUSSION_PROVIDER=anthropic
GWEN_SMART_PROVIDER=anthropic
GWEN_BRAIN_MODEL=claude-haiku-4-5-20251001
GWEN_DISCUSSION_MODEL=claude-haiku-4-5-20251001
GWEN_SMART_MODEL=claude-haiku-4-5-20251001
# Used only for local route-log estimates. Tune this to match your provider.
# GWEN_INPUT_USD_PER_MTOK=0.8

# Optional local fallback.
# GWEN_OLLAMA_MODEL=qwen2.5:3b
# GWEN_OLLAMA_URL=http://127.0.0.1:11434
# Optional explicit Codex binary path for Electron launches that do not inherit
# your terminal PATH.
# CODEX_CLI_PATH=/absolute/path/to/codex
# Code-writing CLI for build_software and fix_self_code: codex | claude
GWEN_CODE_AGENT=codex

# Optional Anthropic cloud mode. Needed for the default router config above.
ANTHROPIC_KEY=
# GWEN_VISION_PROVIDER=anthropic
# GWEN_MEMORY_PROVIDER=anthropic
GWEN_CONFIRM_SENSITIVE_ACTIONS=1
GWEN_SAFE_MODE=0
GWEN_STARTUP_BRIEFING=0
# Global push-to-talk shortcut. On macOS this is Cmd+Option+G.
GWEN_GLOBAL_SHORTCUT=CommandOrControl+Alt+G

# ─── Speech-to-text (all optional — local whisper.cpp is the fallback) ─
# Preferred: Groq (whisper-large-v3-turbo, fastest cloud STT)
# GROQ_KEY=
# Alternative cloud STT: OpenAI (whisper-1)
# OPENAI_KEY=
# With neither key set, Gwen transcribes locally via nodejs-whisper.
# Local model: tiny.en | base.en | small.en | medium.en (default: base.en)
# GWEN_WHISPER_MODEL=base.en
# Local macOS Speech framework testing only:
# GWEN_STT_PROVIDER=macos

# ─── Text-to-speech ───────────────────────────────────────────────────
# Normal voice output uses Fish Audio. For local macOS testing only, set
# GWEN_TTS_PROVIDER=macos to use the built-in `say` command instead.
FISH_KEY=
FISH_VOICE_ID=
GWEN_TTS_PROVIDER=fish

# ─── Google OAuth (Calendar + Gmail read-only) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_TOKEN_PATH=./data/google-token.json

# ─── Web Search (pick one) ────────────────────────────────────────────
TAVILY_KEY=
# BRAVE_KEY=

# ─── Optional flags ───────────────────────────────────────────────────
# Disable screen capture entirely (overrides any agent attempt)
# GWEN_DISABLE_SCREEN=1
# Optional hands-free wake word (https://console.picovoice.ai/)
# PORCUPINE_ACCESS_KEY=
